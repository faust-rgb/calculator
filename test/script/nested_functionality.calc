# Rigorous Testing of Nested Command Functionality

print("--- Symbolic Nesting ---")
# Second derivative: diff(diff(sin(x), x), x) should be -sin(x)
# Note: we use symbolic mode to see the expression
:symbolic on
print("diff(diff(sin(x), x), x) = ", diff(diff(sin(x), x), x))
print("diff(sin(x), x, x) = ", diff(sin(x), x, x))

# Integral of derivative: integral(diff(exp(x), x), x) should be exp(x) + C
print("integral(diff(exp(x), x), x) = ", integral(diff(exp(x), x), x))

# Derivative of integral: diff(integral(sin(x), x), x) should be sin(x)
print("diff(integral(sin(x), x), x) = ", diff(integral(sin(x), x), x))

print("--- Polynomial Nesting ---")
# (x+1)*(x-1) + 1 = x^2 - 1 + 1 = x^2
# poly_add(poly_mul(x + 1, x - 1), 1)
# Note: polynomial commands might expect polynomial strings or variables
p1 = "x + 1"
p2 = "x - 1"
print("poly_add(poly_mul(x + 1, x - 1), 1) = ", poly_add(poly_mul(p1, p2), "1"))

print("--- Matrix Nesting ---")
# det(inverse([1, 2; 3, 4]) * 2) = det(inverse(A)) * det(2*I) = -0.5 * 4 = -2
A = [1, 2; 3, 4]
print("det(inverse(A) * 2) = ", det(inverse(A) * 2))

print("--- Mixed Nesting ---")
# sum(1, 2, mean(3, 4, 5)) = 1 + 2 + 4 = 7
print("sum(1, 2, mean(3, 4, 5)) = ", sum(1, 2, mean(3, 4, 5)))

# Symbolic simplify of nested commands
print("simplify(diff(sin(x)^2 + cos(x)^2)) = ", simplify(diff(sin(x)^2 + cos(x)^2)))
