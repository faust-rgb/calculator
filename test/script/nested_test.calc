# Testing Nested Command Calls

print("=== Nested Matrix Operations ===")
A = [1, 2; 3, 4]
# det(inv(A)) should be 1/det(A) = 1/-2 = -0.5
print("det(inverse(A)) = ", det(inverse(A)))

print("=== Nested Symbolic Operations ===")
# diff(sin(x^2)) = cos(x^2) * 2x
# Note: Defining x to avoid numeric evaluation crash if it happens
x = 0
print("diff(sin(x^2)) = ", diff(sin(x^2)))

print("=== Nested DSP and Matrix ===")
# fft(conv([1,0], [1,1]))
# conv([1,0], [1,1]) = [1, 1, 0]
# Using literal for now as DSP variable resolution is still restricted
print("fft(conv([1, 0], [1, 1])) = ", fft(conv([1, 0], [1, 1])))

print("=== Mixed Module Nesting ===")
# Testing factor(round(mean(...)))
# mean(10, 20, 30, 40) = 25
print("factor(round(mean(10, 20, 30, 40))) = ", factor(round(mean(10, 20, 30, 40))))

print("=== Deep Nesting ===")
# det(A * inverse(A)) should be 1
print("det(A * inverse(A) + [0,0;0,0]) = ", det(A * inverse(A) + [0,0;0,0]))
