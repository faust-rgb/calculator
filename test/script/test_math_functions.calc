# test_math_functions.calc
# Test basic mathematical functions

# Trigonometric functions
sin(pi/2);
cos(0);
tan(pi/4);
asin(1);
acos(1);
atan(1);

# Exponential and logarithmic
exp(1);
ln(e);
log10(100);
sqrt(16);
cbrt(27);
root(16, 4);

# Power functions
pow(2, 10);
pow(3, 4);
root(-8, 3);

# Other functions
abs(-5);
floor(3.7);
ceil(3.2);
sign(-10);
gcd(48, 18);
lcm(4, 6);
mod(17, 5);
min(3, 7);
max(3, 7);

# Constants
pi;
e;
