# Comprehensive Validation Script
# This script exercises various calculator features.
# Note: Some features are known to have limitations (see VALIDATION_REPORT.md).

print("== Starting Validation Script ==")

# 1. Scripting Logic
def fib(n):
    if n <= 1:
        return n
    else:
        return fib(n - 1) + fib(n - 2)

print("fib(7) = ", fib(7)) # Expected: 13

# 2. Linear Algebra (using brackets for robustness)
A = [1, 2; 3, 4]
B = [5, 6; 7, 8]
print("Matrix A: ", A)
print("Matrix B: ", B)
print("A * B: ", A * B + [0,0;0,0])

# 3. Numerical ODE
print("Solving y' = y, y(0) = 1 at x = 1:")
y1 = ode(y, 0, 1, 1)
print("y(1) approx ", y1)

# 4. Symbolic (visual check)
print("Symbolic diff of x^3:")
diff(x^3)

# 5. Signal Processing (literal vector)
print("FFT of [1, 0, 1, 0]:")
fft([1, 0, 1, 0])

# 6. Optimization
print("LP Maximize 3x + 2y subject to x+y<=4, 2x+y<=5:")
lp_max([3, 2], [1, 1; 2, 1], [4, 5], [0, 0], [10, 10])

print("== Validation Script Finished ==")
