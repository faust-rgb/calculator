# ============================================
# 1. 基本语法测试（各保留一个代表性示例）
# ============================================

# 变量赋值
a = 10;
b = 20;
c = a + b;

# 控制流 - if
x = 10;
result = 0;
if (x > 5) {
    result = 1;
}
result;

# 控制流 - for循环
sum = 0;
for (i = 1; i <= 10; i = i + 1) {
    sum = sum + i;
}
sum;

# 控制流 - while循环
sum = 0;
i = 1;
while (i <= 10) {
    sum = sum + i;
    i = i + 1;
}
sum;

# 自定义函数
fn square(x) {
    return x * x;
}

fn fact(n) {
    if (n <= 1) {
        return 1;
    }
    return n * fact(n - 1);
}

square(5) + fact(5);

# ============================================
# 2. 数学函数测试（每类保留一个代表性示例）
# ============================================

# 三角函数
sin(pi/2);
cos(0);
tan(pi/4);

# 指数和对数
exp(1);
ln(e);
sqrt(16);

# 数值辅助
abs(-5);
floor(3.7);
gcd(48, 18);

# 常数
pi;
e;

# ============================================
# 3. 矩阵测试（保留核心操作）
# ============================================

m1 = [1, 2; 3, 4];
m2 = [5, 6; 7, 8];
m1 + m2;

# ============================================
# 4. 符号优化测试（保留独特测试用例）
# ============================================

# 部分分式积分
integral(1 / ((x - 1) ^ 2 * (x + 1)));

# 三角函数积分
integral(sin(x) ^ 2);
integral(cos(x) ^ 2);
integral(tan(x) ^ 2);

# 多变量临界点
critical(x ^ 2 + y ^ 2, x, y);
critical(x ^ 2 - y ^ 2, x, y);

# Pade逼近
pade(exp(x), 2, 2);

# 简化测试
simplify(sqrt(x ^ 2));

# ============================================
# 5. 变换测试（每类保留代表性示例）
# ============================================

# Laplace变换
laplace(1, t, s);
laplace(exp(-2*t), t, s);

# 逆Laplace变换
ilaplace(1/s, s, t);

# Fourier变换
fourier(delta(t), t, w);

# 逆Fourier变换
ifourier(1, w, t);

# Z变换
ztrans(1, n, z);

# 逆Z变换
iztrans(z/(z-1), z, n);

# 往返测试
laplace(step(t), t, s);

# ============================================
# 测试完成
# ============================================
